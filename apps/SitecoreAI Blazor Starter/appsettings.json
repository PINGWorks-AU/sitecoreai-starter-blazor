{
	"Logging": {
		"LogLevel": {
			"Default": "Information",
			"Microsoft.AspNetCore": "Warning"
		}
	},
	"AllowedHosts": "*",

	"SitecoreSettings": {
		/* Put these values into User Secrets */
		"EditingSecret": "[SITECORE_EDITING_SECRET]",
		"EdgeContextId": "[SITECORE_EDGE_CONTEXT_ID]",

		/* Sitecore Deploy -> Projects -> Environments -> Site.Name */
		"SiteName": "blazor-starter-kit",
		"DefaultLanguage": "en",
		/* Languages the site supports. DefaultLanguage is always implicitly included. */
		"AllowedLanguages": [],
		"EnableEditingMode": true,

		/* Default Sitecore navigable item's template name, usually Page. Default 'Page'. */
		"DefaultPageTemplate": "Page",

		/* Add the root URL of your authoring host when deployed, e.g. https://authoring.mysite.com */
		"AuthoringHosts": []
	},

	"SyncSettings": {
		/* One of MemoryAndDisk MemoryOnly Disabled */
		"CachingMode": "Disabled",
		"DataPath": "./App_Data",
		"DiskCacheTimeout": "1.00:00:00",
		"MemoryCacheTimeout": "01:00:00",
		"ChangeFeed": {
			"AutoCreateEdgeWebhook": true,
			"UniqueID": "",
			/* The publicly-reachable base URL of this application. For local development a Microsoft
			   Dev Tunnel works well (https://learn.microsoft.com/azure/developer/dev-tunnels); in
			   deployed environments use the site's public base URL. */
			"WebhookReceiverBase": "[YOUR_PUBLIC_BASE_URL]",

			/* Put these values into User Secrets */
			"ClientID": "[Org or Environment Credentials Client ID]",
			"ClientSecret": "[Org or Environment Credentials Client Secret]"
		},
		"PreloadPaths": [
			"/"
		]
	},

	"ComponentResolverSettings": {
		"SearchNamespaces": [ "*" ]
	},

	/* Configuration for the SendToTeamsProcessor example.
	   The processor matches form submissions to its FormName + ApiKey and posts an Adaptive
	   Card to this webhook URL. Leave WebhookUrl empty to disable. */
	"Teams": {
		"WebhookUrl": ""
	},

	/* Configuration for the SendToEmailProcessor example.
	   Authenticate to Azure Communication Services with either Endpoint (DefaultAzureCredential)
	   or a full ConnectionString. The processor is a no-op until both an address pair and one of
	   the two auth values are set. */
	"Email": {
		"Endpoint": "",
		"ConnectionString": "",
		"FromAddress": "",
		"ToAddress": ""
	}
}
