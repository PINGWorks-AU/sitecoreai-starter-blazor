<div class="component promo @Model.Styles @Model.GridParameters" id="@Id">
	<div class="component-content">

		<div class="field-promoicon">
			<ScImage Field="Model.PromoIcon" />
		</div>

		<div class="promo-text">

			<div>
				<div class="field-promotext">
					<span>
						<ScText Field="@Model.PromoText" />
					</span>
				</div>
			</div>

			<div class="field-promolink">
				<ScLink Field="@Model.PromoLink" />
			</div>

		</div>
	</div>
</div>

@code {
	[Parameter, EditorRequired] public required Components.Promo.ViewModel Model { get; set; }
	[Parameter, EditorRequired] public required string? Id { get; set; }
}
